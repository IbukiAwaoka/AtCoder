{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build active C++ file with g++",
            "type": "shell",
            "command": "g++",
            "args": [
                "${file}",
                "-std=c++17",
                "-g",
                "-O0",
                "-Wall",
                "-Wextra",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the currently active C++ file with g++"
        }
    ]
}